### Root .env example for Vite (frontend)
# Copy this to `.env` or `.env.local` in the project root if you need to override
# Vite picks up variables prefixed with VITE_

# URL of backend API used by the frontend (development default shown)
VITE_API_URL=http://localhost:4000

# Example: if you use a map provider key, add it here
# VITE_MAP_API_KEY=your_map_api_key_here
