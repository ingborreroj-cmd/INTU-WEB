# Global .env example for project root
# Copy this file to `.env` or `.env.local` in the project root.
# Backend code loads the root `.env` and Vite also loads frontend vars with `VITE_` prefix.

# Frontend variables
VITE_API_URL=http://localhost:4000
VITE_ADMIN_PATH=admin
# VITE_ADMIN_PATH define la ruta del panel admin en el frontend React/Vite.
# VITE_MAP_API_KEY=your_map_api_key_here

# Backend variables
PORT=4000
JWT_SECRET=change_this_secret
ADMIN_PATH=admin
# ADMIN_PATH define la misma ruta de admin que usa el backend Express.
# Ambos valores deben ser iguales para que el panel funcionen correctamente.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000
DATABASE_URL=postgresql://<username>:<password>@localhost:5432/intuweb?schema=public
ENABLE_ADMIN_REGISTER=true
# Reemplaza <username> y <password> por las credenciales reales de tu servidor PostgreSQL.
# Si usas el usuario postgres sin contraseña, usa:
# DATABASE_URL=postgresql://postgres@localhost:5432/intuweb?schema=public

# Optional backend LLM / Gemini settings
# Copia este archivo a .env y reemplaza solo tu clave Gemini aquí.
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
# LLM_MAX_TOKENS=450
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=0.95

# Production notes:
# - Use a strong JWT_SECRET in production.
# - Do not commit this .env file to source control.
# - DATABASE_URL must point to a PostgreSQL database.

# Notes:
# - Use this single root `.env` for both frontend and backend.
# - Vite only exposes variables that start with `VITE_`.
# - Prisma uses the root env for backend database configuration.
