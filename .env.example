# Global .env example for project root
# Copy this file to `.env` or `.env.local` in the project root.
# Backend code loads the root `.env` and Vite also loads frontend vars with `VITE_` prefix.

# Frontend variables
VITE_API_URL=http://localhost:4000
# VITE_MAP_API_KEY=your_map_api_key_here

# Backend variables
PORT=4000
JWT_SECRET=change_this_secret
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000
# DATABASE_URL can be a SQLite file path or a full database URI.
# If omitted, the backend uses the default SQLite database inside bakend/src/prisma/db.
# DATABASE_URL=file:./bakend/src/prisma/db/intuweb_db.sqlite

# LLM / Gemini variables
GEMINI_API_KEY=your_gemini_api_key_here
LLM_PROVIDER=gemini
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.95
LLM_MAX_TOKENS=450

# Optional backend flags
ENABLE_ADMIN_REGISTER=false

# Ejemplo para copiar el env
# PORT=4000
# VITE_API_URL=http://localhost:4000
# JWT_SECRET=change_this_secret
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4000
# GEMINI_API_KEY=your_gemini_api_key_here
# LLM_PROVIDER=gemini
# LLM_TEMPERATURE=0.7
# LLM_TOP_P=0.95
# LLM_MAX_TOKENS=450
# ENABLE_ADMIN_REGISTER=false
