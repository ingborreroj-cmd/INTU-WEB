# SQLite local database (Prisma)
DATABASE_URL="file:./prisma/db/intuweb_db.sqlite"

# Secret for signing JWT tokens (change before production)
JWT_SECRET=change_this_secret

# Server port
PORT=4000

# Environment: development | production
NODE_ENV=development

# Toggle whether the public register endpoint is enabled (true|false)
ENABLE_ADMIN_REGISTER=true

# Comma-separated list of allowed CORS origins
# Example: http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
